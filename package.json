{
  "name": "obscura-mcp-server",
  "version": "0.1.2",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/sthbryan/obscura-mcp-server"
  },
  "author": {
    "name": "sthbryan",
    "url": "https://justcallmebryan.com"
  },
  "description": "MCP server for Obscura - web scraping, HTML to Markdown conversion, and URL content processing",
  "main": "./dist/index.js",
  "bin": {
    "obscura-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "biome check --diagnostic-level=error .",
    "smoke": "bun run scripts/smoke-test.ts",
    "test": "bun test",
    "prepublish": "bun run build",
    "postinstall": "[ -d .git ] && lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "latest",
    "@types/turndown": "5.0.6",
    "lefthook": "2.1.10"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "fuse.js": "7.5.0",
    "node-html-parser": "9.0.0",
    "turndown": "7.2.4",
    "zod": "4.4.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "web-scraping",
    "html",
    "markdown"
  ],
  "license": "MIT"
}
